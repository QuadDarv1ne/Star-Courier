# Star Courier Environment Configuration
# Скопируйте этот файл в .env и настройте переменные

# === Настройки игры ===
# Отключить цветной вывод (true/false)
NO_COLOR=false

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Путь к файлу лога
LOG_FILE=game.log

# === Настройки отображения ===
# Задержка между символами при выводе текста (в секундах)
TEXT_SPEED_DELAY=0.02

# Ширина текста в символах
TEXT_WIDTH=80

# === Отладка ===
# Режим отладки (true/false)
DEBUG=false

# Пропускать заставки (true/false)
SKIP_INTRO=false

# === Пути к данным ===
# Директория для сохранений
SAVE_DIR=saves

# Директория с главами
CHAPTERS_DIR=chapters

# Директория с персонажами
CHARACTERS_DIR=characters
